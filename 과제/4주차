n = int(input("1. 입력한 수식 계산 2. 두 수 사이의 합계 : "))

if n == 1:
    s = input("*** 수식을 입력하세요 : ")
    r = eval(s)
    print(s + " 결과는", r, "입니다.")

elif n == 2:
    a = int(input("*** 첫 번째 숫자를 입력하세요 : "))
    b = int(input("*** 두 번째 숫자를 입력하세요 : "))
    total = 0
    for i in range(a, b + 1):
        total = total + i
    print(str(a) + "+...+" + str(b) + "는", total, "입니다.")