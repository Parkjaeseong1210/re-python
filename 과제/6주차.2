from turtle import *
import random

def getText():
    return textinput("문자열 입력", "거북이가 쓸 문자열을 입력")

def getRGB():
    r = random.random()
    g = random.random()
    b = random.random()
    return (r, g, b)

def getXYAS():
    x = random.randint(-250, 250)
    y = random.randint(-250, 250)
    angle = random.randint(0, 360)
    size = random.randint(20, 80)
    return x, y, angle, size

setup(700, 700)
title("거북이 글자쓰기")
shape("turtle")

inStr = getText()

if inStr != None:
    for ch in inStr:
        x, y, angle, size = getXYAS()
        txtColor = getRGB()

        penup()
        goto(x, y)
        setheading(angle)
        pencolor(txtColor)
        write(ch, font=("맑은 고딕", size, "bold"))

done()